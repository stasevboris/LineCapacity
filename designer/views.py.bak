                r_null_ohm_km=float(data.get('r_null_ohm_km', 0)) if data.get('r_null_ohm_km') else None,
                r_add_ohm_km=float(data.get('r_add_ohm_km', 0)) if data.get('r_add_ohm_km') else None,
            )
