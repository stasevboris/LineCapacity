            'r_null_ohm_km': str(l.r_null_ohm_km) if l.r_null_ohm_km else '',
            'r_add_ohm_km': str(l.r_add_ohm_km) if l.r_add_ohm_km else '',
        })
    return JsonResponse({'status': 'success', 'data': data})


