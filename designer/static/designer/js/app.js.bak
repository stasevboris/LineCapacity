// ==========================================
// ИНИЦИАЛИЗАЦИЯ И ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ
// ==========================================
const scene = document.getElementById('scene');
const viewport = document.getElementById('viewport');
const nodesLayer = document.getElementById('nodes-layer');
const linesLayer = document.getElementById('lines-layer');
const handlesLayer = document.getElementById('handles-layer');
const previewLayer = document.getElementById('preview-layer');
const selectRect = document.getElementById('selection-rect');
const ctxMenu = document.getElementById('context-menu');
const sidebarRight = document.getElementById('sidebar-right');
const GRID = 50;

let scale = 1;
let viewX = 0;
let viewY = 0;
let mode = 'SELECT';
let nodes = [];
let lines = [];
let selectedNodeIds = [];
let selectedLineId = null;
let history = [];
let isDrawing = false;
let currentLinePoints = [];
let startNodeId = null;
let pendingLineData = null;
let isPanning = false;
let isDragging = false;
let isSelecting = false;
let startX, startY;
let initialNodes = [];
let initialLines = [];
let draggingHandle = null;
let hoveredNodeId = null;
window.nodeToPlace = null;

// Храним выделенные объекты для группового перемещения
let selectedElements = {
    nodeIds: new Set(),
    lineIds: new Set()
};

const snap = v => Math.round(v / GRID) * GRID;

const getCoords = e => {
    const r = scene.getBoundingClientRect();
    return {
        x: (e.clientX - r.left - viewX) / scale,
        y: (e.clientY - r.top - viewY) / scale
    };
};

// ==========================================
// API ЛОГИКА (ОБНОВЛЕНО ДЛЯ РЕЕСТРА)
// ==========================================
window.currentLoadedSchemeId = null;

// Делаем переменные глобальными для доступа из index.html
window.nodes = nodes;
window.lines = lines;

// Новая функция сохранения с параметрами папки
window.saveToServerWithParams = async function(name, folderId) {
    const payload = {
        name: name,
        folder_id: folderId,
        nodes: nodes,
        lines: lines
    };

    try {
        const response = await fetch('/api/save/', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        });
        const result = await response.json();
        if (result.status === 'success') {
            alert('Схема успешно сохранена в реестр!');
            // Перезагружаем дерево в левой панели (функция из index.html)
            if (window.loadDesignerRegistry) window.loadDesignerRegistry();
        } else {
            alert('Ошибка: ' + result.message);
        }
    } catch (e) {
        alert('Ошибка сети при сохранении.');
    }
};

// Функция для очистки холста и загрузки новых данных
window.loadTopologyData = function(data) {
    saveState(); // Сохраняем текущее в историю перед загрузкой нового
    nodes = data.nodes || [];
    lines = data.lines || [];
    selectedNodeIds = [];
    selectedLineId = null;
    draggingHandle = null;

    // Обновляем глобальные ссылки
    window.nodes = nodes;
    window.lines = lines;

    updateSelectedElements();
    render();
    updateSidebar();
};

// Старая функция (теперь перенаправляет на модалку)
async function saveToServer() {
    if (window.openSaveModal) {
        window.openSaveModal();
    } else {
        const payload = { nodes, lines };
        try {
            const response = await fetch('/api/save/', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });
            const result = await response.json();
            if (result.status === 'success') {
                alert('Схема сохранена успешно!');
            } else {
                alert('Ошибка: ' + result.message);
            }
        } catch (e) {
            alert('Ошибка сети при сохранении.');
        }
    }
}

async function openLoadModal() {
    const listCont = document.getElementById('revisions-list-inner');
    listCont.innerHTML = '<p>Загрузка списка...</p>';
    document.getElementById('modal-overlay').style.display = 'flex';
    try {
        const response = await fetch('/api/list/');
        const result = await response.json();
        if (result.status === 'success') {
            listCont.innerHTML = '';
            if (result.revisions.length === 0) {
                listCont.innerHTML = '<p>Нет сохраненных версий.</p>';
                return;
            }
            result.revisions.forEach(rev => {
                const date = new Date(rev.created_at).toLocaleString();
                const div = document.createElement('div');
                div.className = 'rev-item';
                div.innerHTML = `<span><strong>${rev.label}</strong></span> <small style="color:var(--text-sec)">${date}</small>`;
                div.onclick = () => loadSpecificVersion(rev.id);
                listCont.appendChild(div);
            });
        }
    } catch (e) {
        listCont.innerHTML = 'Ошибка загрузки списка.';
    }
}

async function loadSpecificVersion(id) {
    try {
        const response = await fetch(`/api/load/${id}/`);
        const result = await response.json();
        if (result.status === 'success') {
            window.loadTopologyData(result.topology_data);
            closeModal();
        }
    } catch (e) {
        alert('Ошибка при загрузке данных.');
    }
}

function closeModal() {
    document.getElementById('modal-overlay').style.display = 'none';
}

// ==========================================
// ЛОГИКА КАТАЛОГА
// ==========================================
window.currentCatalogCategory = '';
window.currentCatalogPage = 1;

window.openCatalogModal = function(category, title) {
    window.currentCatalogCategory = category;
    window.currentCatalogPage = 1;
    document.getElementById('catalog-title').innerText = `Каталог: ${title}`;
    document.getElementById('catalog-search').value = '';
    document.getElementById('catalog-modal').style.display = 'flex';
    window.fetchCatalogData();
};

window.closeCatalogModal = function() {
    document.getElementById('catalog-modal').style.display = 'none';
};

window.performCatalogSearch = function() {
    window.currentCatalogPage = 1;
    window.fetchCatalogData();
};

window.changeCatalogPage = function(delta) {
    window.currentCatalogPage += delta;
    window.fetchCatalogData();
};

window.fetchCatalogData = function() {
    const tbody = document.getElementById('catalog-table-body');
    const search = document.getElementById('catalog-search').value;
    tbody.innerHTML = '<tr><td colspan="2" style="text-align:center;padding:40px;color:#888;">Загрузка данных...</td></tr>';

    fetch(`/get_catalog_nodes/?category=${window.currentCatalogCategory}&page=${window.currentCatalogPage}&search=${encodeURIComponent(search)}`)
        .then(res => res.json())
        .then(data => {
            tbody.innerHTML = '';
            if (!data.items || data.items.length === 0) {
                tbody.innerHTML = '<tr><td colspan="2" style="text-align:center;padding:40px;color:#888;">По вашему запросу ничего не найдено.</td></tr>';
                return;
            }

            data.items.forEach(item => {
                const tr = document.createElement('tr');
                const itemName = item.name || 'Без названия';
                tr.innerHTML = `
                    <td style="font-weight:500;">${itemName}${item.power ? ` (${item.power} кВА)` : ''}</td>
                    <td style="text-align:center;">
                        <button class="btn-select-item" onclick="window.selectItemFromCatalog(${item.id}, '${itemName.replace(/'/g, "\\'")}', '${item.type}', '${item.power}')">Выбрать</button>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            document.getElementById('cat-page-info').innerText = `Страница ${data.current_page} из ${data.total_pages}`;
            document.getElementById('btn-cat-prev').disabled = data.current_page <= 1;
            document.getElementById('btn-cat-next').disabled = data.current_page >= data.total_pages;
        })
        .catch(err => {
            console.error(err);
            tbody.innerHTML = '<tr><td colspan="2" style="text-align:center;color:#ff5252;padding:40px;">Ошибка соединения с сервером.</td></tr>';
        });
};

window.selectItemFromCatalog = function(id, name, type, power) {
    window.closeCatalogModal();

    if (type === 'ЛЭП') {
        fetch(`/api/get_node_details/?db_id=${id}&type=ЛЭП`)
            .then(res => res.json())
            .then(data => {
                pendingLineData = {
                    db_id: id,
                    name: name,
                    type: type,
                    params: data.details || {}
                };
                setMode('DRAW');
                document.getElementById('scene').style.cursor = 'crosshair';
            });
        return;
    }

    fetch(`/api/get_node_details/?db_id=${id}&type=${type}`)
        .then(res => res.json())
        .then(data => {
            window.nodeToPlace = {
                db_id: id,
                name: name,
                type: type,
                power: power,
                params: data.details || {}
            };
            document.getElementById('scene').style.cursor = 'crosshair';
        });
};

// ==========================================
// ГЛОБАЛЬНЫЕ КЛАВИШИ
// ==========================================
window.addEventListener('keydown', e => {
    if (e.code === 'Escape') {
        if (window.nodeToPlace) {
            window.nodeToPlace = null;
            previewLayer.innerHTML = '';
            document.getElementById('scene').style.cursor = 'default';
        }
        if (pendingLineData) {
            pendingLineData = null;
            if (mode === 'DRAW') setMode('SELECT');
            isDrawing = false;
            currentLinePoints = [];
            previewLayer.innerHTML = '';
            document.getElementById('scene').style.cursor = 'default';
        }
        return;
    }
    if (e.ctrlKey && e.code === 'KeyZ') {
        e.preventDefault();
        undo();
    }
    if (e.code === 'Delete') {
        deleteSelected();
    }
});

// ==========================================
// ОСНОВНАЯ ЛОГИКА РЕДАКТОРА
// ==========================================
function getOrthogonalSegments(points) {
    if (!points || points.length === 0) return [];
    let res = [{...points[0]}];
    for (let i = 1; i < points.length; i++) {
        let prev = res[res.length - 1];
        let curr = points[i];
        if (prev.x !== curr.x && prev.y !== curr.y) {
            res.push({x: curr.x, y: prev.y});
        }
        res.push({...curr});
    }
    let cleaned = [res[0]];
    for (let i = 1; i < res.length - 1; i++) {
        let prev = cleaned[cleaned.length - 1];
        let curr = res[i];
        let next = res[i + 1];
        if ((prev.x === curr.x && curr.x === next.x) || (prev.y === curr.y && curr.y === next.y)) {
            continue;
        }
        cleaned.push(curr);
    }
    let last = res[res.length - 1];
    let prevCl = cleaned[cleaned.length - 1];
    if (last && prevCl && (last.x !== prevCl.x || last.y !== prevCl.y)) {
        cleaned.push(last);
    }
    return cleaned;
}

function saveState() {
    history.push(JSON.stringify({ nodes, lines }));
    if (history.length > 30) history.shift();
}

function undo() {
    if (history.length > 0) {
        const state = JSON.parse(history.pop());
        nodes = state.nodes;
        lines = state.lines;
        window.nodes = nodes;
        window.lines = lines;
        selectedLineId = null;
        draggingHandle = null;
        hoveredNodeId = null;
        updateSelectedElements();
        render();
        updateSidebar();
    }
}

function setMode(m) {
    mode = m;
    isDrawing = false;
    currentLinePoints = [];
    draggingHandle = null;
    selectedLineId = null;
    hoveredNodeId = null;
    if (m !== 'DRAW') {
        pendingLineData = null;
    }

    document.querySelectorAll('.tool-btn').forEach(b => b.classList.remove('active'));
    const btn = document.getElementById('btn-' + m);
    if (btn) btn.classList.add('active');

    previewLayer.innerHTML = '';
    render();
    updateSidebar();
}

function canConnectToNode(nodeId, lineIdToIgnore = null) {
    const node = nodes.find(n => n.id === nodeId);
    if (!node || node.type === 'TEXT') return false;

    if (node.type === 'Опора') {
        const maxBranches = node.params?.branches_count || 0;
        const connectedLines = lines.filter(l =>
            l.id !== lineIdToIgnore &&
            (l.startNodeId === nodeId || l.endNodeId === nodeId)
        );
        return connectedLines.length < maxBranches;
    }

    return true;
}

function modifyLink(side) {
    if (!selectedLineId) return;
    saveState();
    const line = lines.find(l => l.id === selectedLineId);
    if (side === 'start') line.startNodeId = null;
    if (side === 'end') line.endNodeId = null;
    render();
    updateSidebar();
}

function manualMovePoint() {
    if (!draggingHandle) return;
    saveState();
    const line = lines.find(l => l.id === draggingHandle.lineId);
    const pt = line.points[draggingHandle.index];
    pt.x = snap(parseFloat(document.getElementById('prop-pt-x').value) || pt.x);
    pt.y = snap(parseFloat(document.getElementById('prop-pt-y').value) || pt.y);
    cleanUpOrthogonal();
    render();
}

function cleanUpOrthogonal() {
    lines.forEach(line => {
        if (line.points && line.points.length >= 2) {
            line.points = getOrthogonalSegments(line.points);
        }
    });
}

// Функция обновления выделенных элементов
function updateSelectedElements() {
    selectedElements.nodeIds.clear();
    selectedElements.lineIds.clear();

    selectedNodeIds.forEach(id => selectedElements.nodeIds.add(id));
    if (selectedLineId) selectedElements.lineIds.add(selectedLineId);
}

// Функция для определения, какие линии полностью выделены (все их узлы выделены)
function getFullySelectedLines() {
    const fullySelectedLines = [];

    lines.forEach(line => {
        const isExplicitlySelected = selectedElements.lineIds.has(line.id);
        const startSelected = !line.startNodeId || selectedElements.nodeIds.has(line.startNodeId);
        const endSelected = !line.endNodeId || selectedElements.nodeIds.has(line.endNodeId);

        if (isExplicitlySelected || (startSelected && endSelected)) {
            fullySelectedLines.push(line);
        }
    });

    return fullySelectedLines;
}

// Функция для группового перемещения всех выделенных элементов
function moveSelectedGroup(deltaX, deltaY) {
    const selectedLines = getFullySelectedLines();
    const selectedNodes = nodes.filter(n => selectedElements.nodeIds.has(n.id));

    const nodeMovements = new Map();
    const lineMovements = new Map();

    selectedNodes.forEach(node => {
        const initialNode = initialNodes.find(inode => inode.id === node.id);
        if (initialNode) {
            nodeMovements.set(node.id, {
                x: initialNode.x + deltaX,
                y: initialNode.y + deltaY
            });
        }
    });

    selectedLines.forEach(line => {
        const initialLine = initialLines.find(iline => iline.id === line.id);
        if (initialLine) {
            const newPoints = initialLine.points.map(point => ({
                x: point.x + deltaX,
                y: point.y + deltaY
            }));
            lineMovements.set(line.id, newPoints);
        }
    });

    nodeMovements.forEach((pos, nodeId) => {
        const node = nodes.find(n => n.id === nodeId);
        if (node) {
            node.x = snap(pos.x);
            node.y = snap(pos.y);
        }
    });

    lineMovements.forEach((newPoints, lineId) => {
        const line = lines.find(l => l.id === lineId);
        if (line) {
            line.points = newPoints.map(p => ({x: snap(p.x), y: snap(p.y)}));
            if (line.startNodeId && selectedElements.nodeIds.has(line.startNodeId)) {
                const startNode = nodes.find(n => n.id === line.startNodeId);
                if (startNode && line.points[0]) {
                    line.points[0].x = startNode.x;
                    line.points[0].y = startNode.y;
                }
            }
            if (line.endNodeId && selectedElements.nodeIds.has(line.endNodeId)) {
                const endNode = nodes.find(n => n.id === line.endNodeId);
                if (endNode && line.points[line.points.length - 1]) {
                    line.points[line.points.length - 1].x = endNode.x;
                    line.points[line.points.length - 1].y = endNode.y;
                }
            }
            line.points = getOrthogonalSegments(line.points);
        }
    });
}

// ==========================================
// СОБЫТИЯ МЫШИ НА ХОЛСТЕ
// ==========================================
scene.onmousedown = (e) => {
    if (ctxMenu) ctxMenu.style.display = 'none';
    const c = getCoords(e);

    if (mode === 'DRAW') {
        if (e.button === 2) {
            pendingLineData = null;
            setMode('SELECT');
            document.getElementById('scene').style.cursor = 'default';
            isDrawing = false;
            currentLinePoints = [];
            previewLayer.innerHTML = '';
            return;
        }

        const hitNode = nodes.find(n => Math.hypot(n.x - c.x, n.y - c.y) < 25);

        if (!isDrawing && hitNode && hitNode.type !== 'TEXT') {
            if (!canConnectToNode(hitNode.id)) {
                alert(`Невозможно начать ЛЭП от "${hitNode.name}" (достигнут лимит подключений для опоры).`);
                return;
            }
            saveState();
            isDrawing = true;
            startNodeId = hitNode.id;
            currentLinePoints = [{ x: hitNode.x, y: hitNode.y }];
        } else if (isDrawing) {
            currentLinePoints.push({ x: snap(c.x), y: snap(c.y) });
            if (hitNode && hitNode.id !== startNodeId && hitNode.type !== 'TEXT') {
                if (!canConnectToNode(hitNode.id)) {
                    alert(`Невозможно завершить ЛЭП на "${hitNode.name}" (достигнут лимит подключений для опоры).`);
                    return;
                }

                const newLine = {
                    id: Date.now(),
                    name: pendingLineData ? pendingLineData.name : "ЛЭП",
                    points: [...currentLinePoints],
                    startNodeId: startNodeId,
                    endNodeId: hitNode.id,
                    type: 'ЛЭП',
                    db_id: pendingLineData ? pendingLineData.db_id : null,
                    mark: pendingLineData ? (pendingLineData.params['Марка ЛЭП'] || pendingLineData.name) : '',
                    material: pendingLineData ? (pendingLineData.params['Материал провода'] || '') : '',
                    insulation: pendingLineData ? (pendingLineData.params['Материал изоляции'] || '') : '',
                    cores_count: pendingLineData ? (pendingLineData.params['Количество жил'] || '') : '',
                    cross_section: pendingLineData ? (pendingLineData.params['Сечение фазного провода, мм²'] || '') : '',
                    r_phase_ohm_km: pendingLineData ? (pendingLineData.params['Сопротивление фазного, Ом/км'] || '') : '',
                    r_null_ohm_km: pendingLineData ? (pendingLineData.params['Сопротивление нулевого, Ом/км'] || '') : '',
                    r_add_ohm_km: pendingLineData ? (pendingLineData.params['Сопротивление доп. провода, Ом/км'] || '') : ''
                };
                lines.push(newLine);
                cleanUpOrthogonal();
                isDrawing = false;
                startNodeId = null;
                currentLinePoints = [];
                pendingLineData = null;
                setMode('SELECT');
                document.getElementById('scene').style.cursor = 'default';
            }
        }
        render();
        updateSidebar();
        return;
    }

    if (window.nodeToPlace) {
        if (e.button === 2) {
            window.nodeToPlace = null;
            previewLayer.innerHTML = '';
            document.getElementById('scene').style.cursor = 'default';
            return;
        }
        saveState();
        const nodeData = window.nodeToPlace;
        const newNode = {
            id: Date.now(),
            x: snap(c.x),
            y: snap(c.y),
            type: nodeData.type,
            name: nodeData.name,
            db_id: nodeData.db_id,
            params: nodeData.params || {}
        };
        if (newNode.type === 'Опора') {
            if (newNode.params.branches_count === undefined) newNode.params.branches_count = 0;
        } else if (['ТП', 'Абонент'].includes(newNode.type)) {
            if (!newNode.params) newNode.params = {};
        }
        nodes.push(newNode);
        window.nodeToPlace = null;
        document.getElementById('scene').style.cursor = 'default';
        previewLayer.innerHTML = '';
        selectedNodeIds = [newNode.id];
        selectedLineId = null;
        updateSelectedElements();
        render();
        updateSidebar();
        return;
    }

    const hitNode = nodes.find(n => Math.hypot(n.x - c.x, n.y - c.y) < 25);

    if (e.button === 2 || e.button === 1) {
        isPanning = true;
        startX = e.clientX - viewX;
        startY = e.clientY - viewY;
        return;
    }

    if (selectedLineId && mode === 'SELECT') {
        const line = lines.find(l => l.id === selectedLineId);
        const hIdx = line.points.findIndex(p => Math.hypot(p.x - c.x, p.y - c.y) < 15);
        if (hIdx !== -1) {
            saveState();
            draggingHandle = { lineId: selectedLineId, index: hIdx };
            updateSidebar();
            return;
        }
    }

    if (mode === 'SELECT') {
        if (hitNode) {
            saveState();
            selectedLineId = null;
            draggingHandle = null;

            if (!e.shiftKey) {
                selectedNodeIds = [hitNode.id];
            } else {
                if (!selectedNodeIds.includes(hitNode.id)) {
                    selectedNodeIds.push(hitNode.id);
                } else {
                    selectedNodeIds = selectedNodeIds.filter(id => id !== hitNode.id);
                }
            }

            updateSelectedElements();
            isDragging = true;

            initialNodes = nodes.map(n => ({...n}));
            initialLines = lines.map(l => ({
                ...l,
                points: l.points.map(p => ({...p}))
            }));

            startX = c.x;
            startY = c.y;
        } else {
            const hitLine = findLineAt(c.x, c.y);
            if (hitLine) {
                if (!e.shiftKey) {
                    selectedLineId = hitLine.id;
                    selectedNodeIds = [];
                } else {
                    if (selectedLineId === hitLine.id) {
                        selectedLineId = null;
                    } else {
                        selectedLineId = hitLine.id;
                    }
                }
                updateSelectedElements();

                if (!e.shiftKey || selectedLineId) {
                    isDragging = true;
                    initialNodes = nodes.map(n => ({...n}));
                    initialLines = lines.map(l => ({
                        ...l,
                        points: l.points.map(p => ({...p}))
                    }));
                    startX = c.x;
                    startY = c.y;
                }
            } else {
                isSelecting = true;
                if (!e.shiftKey) {
                    selectedNodeIds = [];
                    selectedLineId = null;
                    updateSelectedElements();
                }
                startX = c.x;
                startY = c.y;
                if(selectRect) selectRect.style.display = 'block';
            }
        }
    } else if (mode === 'TEXT') {
        saveState();
        const textNode = {
            id: Date.now(),
            x: snap(c.x),
            y: snap(c.y),
            type: 'TEXT',
            name: 'Ваш текст',
            fontSize: 16
        };
        nodes.push(textNode);
        selectedNodeIds = [textNode.id];
        updateSelectedElements();
        setMode('SELECT');
    }

    render();
    updateSidebar();
};

window.onmousemove = (e) => {
    const c = getCoords(e);

    if (window.nodeToPlace) {
        previewLayer.innerHTML = `
            <circle cx="${snap(c.x)}" cy="${snap(c.y)}" r="15" fill="rgba(46,204,113,0.4)" stroke="#2ecc71" stroke-width="2" stroke-dasharray="4"/>
            <text x="${snap(c.x)}" y="${snap(c.y) + 35}" fill="#fff" font-size="11" text-anchor="middle">${window.nodeToPlace.name}</text>
        `;
        return;
    }

    if (mode === 'DRAW' && isDrawing) {
        const tempPts = [...currentLinePoints, {x: snap(c.x), y: snap(c.y)}];
        const orthoPts = getOrthogonalSegments(tempPts);
        previewLayer.innerHTML = `<polyline points="${orthoPts.map(p => `${p.x},${p.y}`).join(' ')}" class="drawing-line"/>`;
        return;
    }

    if (isPanning) {
        viewX = e.clientX - startX;
        viewY = e.clientY - startY;
        updateTransform();
        return;
    }

    if (draggingHandle) {
        const line = lines.find(l => l.id === draggingHandle.lineId);
        const pt = line.points[draggingHandle.index];
        pt.x = snap(c.x);
        pt.y = snap(c.y);
        hoveredNodeId = null;

        if (draggingHandle.index === 0 || draggingHandle.index === line.points.length - 1) {
            const nearNode = nodes.find(n =>
                n.type !== 'TEXT' &&
                Math.hypot(n.x - pt.x, n.y - pt.y) < 40
            );

            if (nearNode && canConnectToNode(nearNode.id, line.id)) {
                pt.x = nearNode.x;
                pt.y = nearNode.y;
                hoveredNodeId = nearNode.id;
            }
        }

        if (document.getElementById('prop-pt-x')) {
            document.getElementById('prop-pt-x').value = pt.x;
            document.getElementById('prop-pt-y').value = pt.y;
        }
        render();
        return;
    }

    if (isSelecting) {
        const x = Math.min(c.x, startX);
        const y = Math.min(c.y, startY);
        const w = Math.abs(c.x - startX);
        const h = Math.abs(c.y - startY);
        selectRect.setAttribute('x', x);
        selectRect.setAttribute('y', y);
        selectRect.setAttribute('width', w);
        selectRect.setAttribute('height', h);

        const newSelectedNodes = nodes.filter(n => n.x >= x && n.x <= x + w && n.y >= y && n.y <= y + h).map(n => n.id);
        selectedNodeIds = newSelectedNodes;
        selectedLineId = null;
        updateSelectedElements();
        render();
    }

    if (isDragging && !draggingHandle) {
        const dx = c.x - startX;
        const dy = c.y - startY;
        moveSelectedGroup(dx, dy);
        render();
    }
};

window.onmouseup = () => {
    if (draggingHandle) {
        const line = lines.find(l => l.id === draggingHandle.lineId);
        const pt = line.points[draggingHandle.index];
        const nearNode = nodes.find(n =>
            n.type !== 'TEXT' &&
            Math.hypot(n.x - pt.x, n.y - pt.y) < 40
        );

        if (nearNode && canConnectToNode(nearNode.id, line.id)) {
            if (draggingHandle.index === 0) {
                line.startNodeId = nearNode.id;
            } else if (draggingHandle.index === line.points.length - 1) {
                line.endNodeId = nearNode.id;
            }
        } else {
            if (draggingHandle.index === 0) {
                line.startNodeId = null;
            } else if (draggingHandle.index === line.points.length - 1) {
                line.endNodeId = null;
            }
        }
    }
    isPanning = false;
    isSelecting = false;
    isDragging = false;
    draggingHandle = null;
    hoveredNodeId = null;
    if (selectRect) selectRect.style.display = 'none';
    cleanUpOrthogonal();
    render();
    updateSidebar();
};

scene.ondblclick = () => {
    if (mode === 'DRAW' && isDrawing) {
        isDrawing = false;
        currentLinePoints = [];
        previewLayer.innerHTML = '';
        pendingLineData = null;
        setMode('SELECT');
    }
};

// ==========================================
// ОТРИСОВКА (ИЗМЕНЕНО ДЛЯ SVG-ИКОНОК)
// ==========================================
function render() {
    nodesLayer.innerHTML = '';
    linesLayer.innerHTML = '';
    handlesLayer.innerHTML = '';

    lines.forEach(line => {
        const sn = nodes.find(n => n.id === line.startNodeId);
        const en = nodes.find(n => n.id === line.endNodeId);
        if (sn) { line.points[0].x = sn.x; line.points[0].y = sn.y; }
        if (en) { line.points[line.points.length - 1].x = en.x; line.points[line.points.length - 1].y = en.y; }

        const orthoPts = getOrthogonalSegments(line.points);
        const poly = document.createElementNS("http://www.w3.org/2000/svg", "polyline");
        poly.setAttribute('points', orthoPts.map(p => `${p.x},${p.y}`).join(' '));
        poly.classList.add('line-path');

        if (line.mark || line.name) {
            const midIndex = Math.floor(orthoPts.length / 2);
            const midPoint = orthoPts[midIndex];
            const text = document.createElementNS("http://www.w3.org/2000/svg", "text");
            text.setAttribute('x', midPoint.x);
            text.setAttribute('y', midPoint.y - 10);
            text.setAttribute('fill', '#aaa');
            text.setAttribute('font-size', '10');
            text.setAttribute('text-anchor', 'middle');
            text.textContent = line.mark || line.name;
            text.style.pointerEvents = 'none';
            linesLayer.appendChild(text);
        }

        if (selectedLineId === line.id) {
            poly.classList.add('selected');
            line.points.forEach((p, idx) => {
                const h = document.createElementNS("http://www.w3.org/2000/svg", "circle");
                h.setAttribute('cx', p.x);
                h.setAttribute('cy', p.y);
                h.setAttribute('r', 6);
                h.classList.add('line-handle');
                if (draggingHandle && draggingHandle.lineId === line.id && draggingHandle.index === idx) {
                    h.classList.add('active');
                }
                handlesLayer.appendChild(h);
            });
        }
        linesLayer.appendChild(poly);
    });

    nodes.forEach(n => {
        const g = document.createElementNS("http://www.w3.org/2000/svg", "g");

        // Отрисовка простого текста
        if (n.type === 'TEXT') {
            const t = document.createElementNS("http://www.w3.org/2000/svg", "text");
            t.setAttribute('x', n.x);
            t.setAttribute('y', n.y);
            t.textContent = n.name;
            t.classList.add('text-node');
            t.style.fontSize = (n.fontSize || 16) + 'px';
            if (selectedNodeIds.includes(n.id)) t.classList.add('selected');
            g.appendChild(t);
            nodesLayer.appendChild(g);
            return;
        }

        // --- УМНАЯ ОТРИСОВКА (Картинка или Заглушка) ---
        const nodeVisuals = document.createElementNS("http://www.w3.org/2000/svg", "g");
        nodeVisuals.classList.add('node');

        // 1. Определяем цвета для запасных кружков (если картинки нет)
        let fallbackColor = "#7f8c8d"; // По умолчанию серый
        if (n.type === 'ТП') fallbackColor = "#e74c3c";       // Красный
        if (n.type === 'Опора') fallbackColor = "#3498db";    // Синий
        if (n.type === 'Абонент') fallbackColor = "#2ecc71";  // Зеленый

        // 2. Создаем запасной круг (Фолбэк)
        const fallbackCircle = document.createElementNS("http://www.w3.org/2000/svg", "circle");
        fallbackCircle.setAttribute('cx', n.x);
        fallbackCircle.setAttribute('cy', n.y);
        fallbackCircle.setAttribute('r', 15);
        fallbackCircle.setAttribute('fill', '#1e1e1e'); // Темный фон редактора
        fallbackCircle.setAttribute('stroke', fallbackColor);
        fallbackCircle.setAttribute('stroke-width', '3');
        nodeVisuals.appendChild(fallbackCircle);

        // 3. Создаем текст ошибки "Нет фото" (скрыт по умолчанию)
        const errorText = document.createElementNS("http://www.w3.org/2000/svg", "text");
        errorText.setAttribute('x', n.x);
        errorText.setAttribute('y', n.y + 3); // Центрируем по вертикали
        errorText.setAttribute('fill', '#e74c3c'); // Красный цвет
        errorText.setAttribute('font-size', '9px');
        errorText.setAttribute('text-anchor', 'middle');
        errorText.setAttribute('font-weight', 'bold');
        errorText.setAttribute('pointer-events', 'none'); // Чтобы клики проходили сквозь текст
        errorText.textContent = "Нет фото";
        errorText.style.display = 'none'; // Скрываем
        nodeVisuals.appendChild(errorText);

        // 4. Пытаемся загрузить векторную графику
        const iconSize = 40;
        const offset = iconSize / 2;

        // Пути к картинкам в папке static
        let iconPath = '';
        if (n.type === 'ТП') iconPath = '/static/designer/icons/tp.svg';
        if (n.type === 'Опора') iconPath = '/static/designer/icons/pole.svg';
        if (n.type === 'Абонент') iconPath = '/static/designer/icons/home.svg';

        if (iconPath) {
            const img = document.createElementNS("http://www.w3.org/2000/svg", "image");
            img.setAttribute('href', iconPath);
            img.setAttribute('x', n.x - offset);
            img.setAttribute('y', n.y - offset);
            img.setAttribute('width', iconSize);
            img.setAttribute('height', iconSize);

            // Если картинка загрузилась успешно - скрываем запасной круг
            img.addEventListener('load', () => {
                fallbackCircle.style.display = 'none';
            });

            // Если картинка не найдена (ошибка 404)
            img.addEventListener('error', () => {
                img.style.display = 'none'; // Прячем сломанную картинку
                errorText.style.display = 'block'; // Показываем надпись "Нет фото"
            });

            // Добавляем классы выделения на саму картинку
            if (selectedNodeIds.includes(n.id)) img.classList.add('selected');
            if (hoveredNodeId === n.id) img.classList.add('can-attach');

            nodeVisuals.appendChild(img);
        } else {
            // Если путь для типа не задан, показываем ошибку
            errorText.style.display = 'block';
        }

        // Применяем логику выделения (желтое или зеленое свечение) на фолбэк
        if (selectedNodeIds.includes(n.id)) fallbackCircle.classList.add('selected');
        if (hoveredNodeId === n.id) fallbackCircle.classList.add('can-attach');

        g.appendChild(nodeVisuals);

        // 5. Отрисовка названия объекта снизу
        const t = document.createElementNS("http://www.w3.org/2000/svg", "text");
        t.setAttribute('x', n.x);
        t.setAttribute('y', n.y + 35);
        t.textContent = n.name;
        t.classList.add('node-label');

        g.appendChild(t);
        nodesLayer.appendChild(g);
    });
}

function findLineAt(x, y) {
    return lines.find(l => {
        const orthoPts = getOrthogonalSegments(l.points);
        for (let i = 0; i < orthoPts.length - 1; i++) {
            if (distToSeg({x, y}, orthoPts[i], orthoPts[i + 1]) < 10) return true;
        }
        return false;
    });
}

function distToSeg(p, v, w) {
    const l2 = Math.pow(v.x - w.x, 2) + Math.pow(v.y - w.y, 2);
    if (l2 === 0) return Math.hypot(p.x - v.x, p.y - v.y);
    let t = Math.max(0, Math.min(1, ((p.x - v.x) * (w.x - v.x) + (p.y - v.y) * (w.y - v.y)) / l2));
    return Math.hypot(p.x - (v.x + t * (w.x - v.x)), p.y - (v.y + t * (w.y - v.y)));
}

function updateConnectionsInfo(poleId) {
    const pole = nodes.find(n => n.id === poleId && n.type === 'Опора');
    if (!pole) return;
    const maxBranches = pole.params?.branches_count || 0;
    const connectedLines = lines.filter(l => l.startNodeId === poleId || l.endNodeId === poleId);
    const connectionsList = document.getElementById('connections-list');
    if (connectionsList) {
        if (connectedLines.length === 0) {
            connectionsList.innerHTML = '<span style="color:#888;">Нет подключений</span>';
        } else {
            connectionsList.innerHTML = `<span style="color:${connectedLines.length > maxBranches ? '#ff5252' : '#2ecc71'}">Подключено: ${connectedLines.length} / ${maxBranches}</span>`;
            if (connectedLines.length > maxBranches) {
                connectionsList.innerHTML += '<div style="color:#ff5252;margin-top:5px;">⚠️ Превышен лимит подключений!</div>';
            }
        }
    }
}

// ==========================================
// ПАНЕЛЬ СВОЙСТВ
// ==========================================
function escapeHtml(s) {
    return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

function renderDynamicProps(n, container) {
    let html = `
        <div class="prop-group">
            <label>Тип объекта</label>
            <input type="text" value="${escapeHtml(n.type || 'Неизвестно')}" readonly style="color: var(--text-sec); background: #242424; cursor: default;">
        </div>`;
    if (n.db_id) {
        html += `
            <div class="prop-group">
                <label>ID в Базе Данных</label>
                <input type="text" value="${escapeHtml(n.db_id)}" readonly style="color: var(--text-sec); font-family: monospace; background: #242424; cursor: default;">
            </div>`;
    }
    if (n.params && Object.keys(n.params).length > 0) {
        for (const [key, value] of Object.entries(n.params)) {
            if (value === null || value === undefined || value === '') continue;
            html += `
                <div class="prop-group">
                    <label>${escapeHtml(key)}</label>
                    <input type="text" value="${escapeHtml(value)}" readonly style="color: var(--text-sec); background: #242424; font-weight: bold; font-size: 12px; cursor: default;">
                </div>`;
        }
    } else if (!n.db_id) {
        html += `<div style="color:#888;font-size:11px;padding:10px;">Объект не привязан к справочнику</div>`;
    }
    container.innerHTML = html;
}

function updateSidebar() {
    sidebarRight.style.display = 'none';
    const blocks = ['text-props', 'pole-props', 'line-props', 'transformer-props', 'consumer-props'];
    blocks.forEach(id => {
        const el = document.getElementById(id);
        if (el) el.style.display = 'none';
    });
    const dynContainer = document.getElementById('dynamic-props-container');
    if (dynContainer) dynContainer.innerHTML = '';

    if (selectedNodeIds.length === 1) {
        const n = nodes.find(node => node.id === selectedNodeIds[0]);
        if (!n) return;
        sidebarRight.style.display = 'block';

        if (n.type === 'TEXT') {
            document.getElementById('text-props').style.display = 'block';
            document.getElementById('props-title').innerText = "Текст";
            document.getElementById('lbl-name').innerText = "Содержимое";
            document.getElementById('prop-name').value = n.name || '';
            document.getElementById('prop-text-size').value = n.fontSize || 16;
        } else if (n.type === 'Опора') {
            document.getElementById('pole-props').style.display = 'block';
            document.getElementById('props-title').innerText = "Свойства опоры";
            document.getElementById('lbl-name').innerText = "Наименование";
            document.getElementById('prop-name').value = n.name || '';
            document.getElementById('pole-branches').value = n.params?.branches_count || 0;
            updateConnectionsInfo(n.id);
        } else {
            document.getElementById('props-title').innerText = `Свойства: ${n.type || 'объект'}`;
            document.getElementById('lbl-name').innerText = "Наименование";
            document.getElementById('prop-name').value = n.name || '';

            const hasLocalParams = n.params && Object.keys(n.params).filter(k => k !== 'branches_count').length > 0;

            if (hasLocalParams || !n.db_id) {
                renderDynamicProps(n, dynContainer);
            } else {
                dynContainer.innerHTML = '<div style="color:#888;font-size:12px;padding:10px;">Загрузка свойств из БД...</div>';
                const selectedAtFetch = n.id;
                fetch(`/api/get_node_details/?db_id=${encodeURIComponent(n.db_id)}&type=${encodeURIComponent(n.type)}`)
                    .then(res => res.json())
                    .then(data => {
                        if (data.details && Object.keys(data.details).length > 0) {
                            n.params = { ...(n.params || {}), ...data.details };
                        }
                        if (selectedNodeIds.length === 1 && selectedNodeIds[0] === selectedAtFetch) {
                            renderDynamicProps(n, dynContainer);
                        }
                    })
                    .catch(() => {
                        if (selectedNodeIds.length === 1 && selectedNodeIds[0] === selectedAtFetch) {
                            dynContainer.innerHTML = '<div style="color:#ff5252;">Ошибка связи с БД</div>';
                        }
                    });
            }
        }
    } else if (selectedLineId) {
        const l = lines.find(line => line.id === selectedLineId);
        if (!l) return;
        sidebarRight.style.display = 'block';
        document.getElementById('line-props').style.display = 'block';
        document.getElementById('props-title').innerText = "Свойства ЛЭП";
        document.getElementById('lbl-name').innerText = "Наименование";
        document.getElementById('prop-name').value = l.name || '';
        document.getElementById('prop-mark').value = l.mark || '';
        document.getElementById('prop-material').value = l.material || '';
        document.getElementById('prop-insulation').value = l.insulation || '';
        document.getElementById('prop-cores').value = l.cores_count || '';
        document.getElementById('prop-cross-section').value = l.cross_section || '';
        document.getElementById('prop-r-phase').value = l.r_phase_ohm_km || '';
        document.getElementById('prop-r-null').value = l.r_null_ohm_km || '';
        document.getElementById('prop-r-add').value = l.r_add_ohm_km || '';

        if (draggingHandle && draggingHandle.lineId === selectedLineId) {
            document.getElementById('point-editor').style.display = 'block';
            document.getElementById('prop-pt-x').value = l.points[draggingHandle.index].x;
            document.getElementById('prop-pt-y').value = l.points[draggingHandle.index].y;
        } else {
            document.getElementById('point-editor').style.display = 'none';
        }

        if (document.getElementById('btn-unlink-start')) {
            document.getElementById('btn-unlink-start').disabled = !l.startNodeId;
            document.getElementById('btn-unlink-end').disabled = !l.endNodeId;
        }
    }
}

// --- DRAG AND DROP ---
const canvasCont = document.getElementById('canvas-container');
canvasCont.ondragover = e => e.preventDefault();
canvasCont.ondrop = e => {
    const rawData = e.dataTransfer.getData('app/node-data');
    if (!rawData) return;
    const nodeData = JSON.parse(rawData);
    saveState();
    const c = getCoords(e);
    const newNode = {
        id: Date.now(),
        x: snap(c.x),
        y: snap(c.y),
        type: nodeData.type,
        name: nodeData.name,
        db_id: null,
        params: {}
    };
    if (newNode.type === 'Опора') {
        newNode.params.branches_count = 0;
    } else if (['ТП', 'Абонент'].includes(newNode.type)) {
        newNode.params = {};
    }
    nodes.push(newNode);
    render();
    updateSidebar();
};

function initDragAndDrop() {
    document.querySelectorAll('.lib-item[data-type]').forEach(i => {
        i.ondragstart = e => {
            const cleanName = i.innerText.replace('🗼 ', '').replace('⚡ ', '').replace('🏠 ', '').trim();
            const dataToTransfer = {
                type: i.dataset.type,
                name: cleanName
            };
            e.dataTransfer.setData('app/node-data', JSON.stringify(dataToTransfer));
        };
    });
}

// --- ЗУМ ---
scene.onwheel = e => {
    e.preventDefault();
    scale *= (e.deltaY > 0 ? 0.9 : 1.1);
    updateTransform();
};

function updateTransform() {
    viewport.setAttribute('transform', `translate(${viewX},${viewY}) scale(${scale})`);
}

scene.oncontextmenu = e => {
    e.preventDefault();
    if (selectedNodeIds.length > 0 || selectedLineId) {
        ctxMenu.style.display = 'block';
        ctxMenu.style.left = e.clientX + 'px';
        ctxMenu.style.top = e.clientY + 'px';
    }
};

// --- ОБНОВЛЕНИЯ UI ---
window.updateNodeName = function(v) {
    saveState();
    if (selectedNodeIds.length === 1) {
        const n = nodes.find(n => n.id === selectedNodeIds[0]);
        if (n) n.name = v;
    } else if (selectedLineId) {
        const l = lines.find(l => l.id === selectedLineId);
        if (l) l.name = v;
    }
    render();
};

window.updateTextSize = function(v) {
    if (selectedNodeIds.length !== 1) return;
    saveState();
    const n = nodes.find(n => n.id === selectedNodeIds[0]);
    if (n && n.type === 'TEXT') {
        n.fontSize = parseInt(v) || 16;
        render();
    }
};

window.updateLineParam = function(param, value) {
    if (!selectedLineId) return;
    saveState();
    const l = lines.find(l => l.id === selectedLineId);
    if (l) {
        l[param] = value;
        if (param === 'mark') l.name = value;
    }
    render();
};

window.updateNodeParam = function(param, value) {
    if (selectedNodeIds.length !== 1) return;
    saveState();
    const n = nodes.find(n => n.id === selectedNodeIds[0]);
    if (n) {
        if (!n.params) n.params = {};
        n.params[param] = value;
    }
    render();
};

window.deleteSelected = function() {
    saveState();
    nodes = nodes.filter(n => !selectedNodeIds.includes(n.id));
    lines = lines.filter(l =>
        l.id !== selectedLineId &&
        !selectedNodeIds.includes(l.startNodeId) &&
        !selectedNodeIds.includes(l.endNodeId)
    );
    selectedNodeIds = [];
    selectedLineId = null;
    draggingHandle = null;
    updateSelectedElements();
    if(ctxMenu) ctxMenu.style.display = 'none';
    sidebarRight.style.display = 'none';
    render();
};

// Экспорт глобальных функций
window.saveToServer = saveToServer;
window.openLoadModal = openLoadModal;
window.undo = undo;
window.setMode = setMode;
window.modifyLink = modifyLink;
window.manualMovePoint = manualMovePoint;
window.deleteSelected = deleteSelected;
window.openCatalogModal = openCatalogModal;
window.closeCatalogModal = closeCatalogModal;
window.performCatalogSearch = performCatalogSearch;
window.changeCatalogPage = changeCatalogPage;
window.fetchCatalogData = fetchCatalogData;
window.selectItemFromCatalog = selectItemFromCatalog;
window.updateNodeName = updateNodeName;
window.updateTextSize = updateTextSize;
window.updateLineParam = updateLineParam;
window.updateNodeParam = updateNodeParam;

// Инициализация
updateTransform();
document.addEventListener('DOMContentLoaded', initDragAndDrop);